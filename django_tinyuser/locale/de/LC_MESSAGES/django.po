#: django_tinyuser/global_templates/bootstrap/account/email_confirm.html:16
#, python-format
msgid ""
"Please confirm that <a href=\"mailto:%(email)s\">%(email)s</a> is an email "
"address for user %(user_display)s."
msgstr "Bitte bestätigen Sie, dass <a href=\"mailto:%(email)s\">%(email)s</a> eine E-Mail-Adresse für den Benutzer %(user_display)s ist."

#: django_tinyuser/global_templates/bootstrap/account/email_confirm.html:25
msgid "Confirm"
msgstr "Bestätigen"

#: django_tinyuser/global_templates/bootstrap/account/email_confirm.html:32
#, python-format
msgid ""
"Unable to confirm %(email)s because it is already confirmed by a different "
"account."
msgstr "Konnte %(email)s nicht bestätigen, da es bereits von einem anderen Konto bestätigt wurde."

#: django_tinyuser/global_templates/bootstrap/account/email_confirm.html:38
#, python-format
msgid ""
"This email confirmation link expired or is invalid. Please <a "
"href=\"%(email_url)s\">issue a new email confirmation request</a>."
msgstr "Dieser Bestätigungslink für die E-Mail ist abgelaufen oder ungültig. Bitte <a href=\"%(email_url)s\">stellen Sie eine neue E-Mail-Bestätigungsanforderung</a>."

